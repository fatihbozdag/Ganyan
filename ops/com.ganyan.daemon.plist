<?xml version="1.0" encoding="UTF-8"?>
<!--
  Headless Ganyan scheduler daemon (no Flask web UI).
  Use this if you want ONLY the scheduled jobs and nothing else.

  Install:
    cp ops/com.ganyan.daemon.plist ~/Library/LaunchAgents/
    launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.ganyan.daemon.plist

  Alternative to com.ganyan.web.plist — pick ONE of the two, not both
  (the web plist already includes the scheduler in-process).

  Stop / uninstall:
    launchctl bootout gui/$(id -u)/com.ganyan.daemon
    rm ~/Library/LaunchAgents/com.ganyan.daemon.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.ganyan.daemon</string>

    <key>WorkingDirectory</key>
    <string>/Users/fatihbozdag/Downloads/Cursor-Projects/ganyan</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/uv</string>
        <string>run</string>
        <string>ganyan</string>
        <string>daemon</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
    </dict>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/ganyan-daemon.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/ganyan-daemon.err</string>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>Nice</key>
    <integer>5</integer>
</dict>
</plist>
